---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: object;
}

const { title, description, image = '/images/hero-chemin.jpg', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>

  <body>
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#f8f4ee]/95 backdrop-blur-sm border-b border-stone-200">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/logo.svg" alt="Une Escale Gourmande" class="h-12 w-auto" />
          <span class="font-serif text-lg text-[#1a1a1a] hidden sm:block">Une Escale Gourmande</span>
        </a>
        <button id="menu-btn" class="lg:hidden p-2" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-stone-700 mb-1.5"></span>
          <span class="block w-6 h-0.5 bg-stone-700 mb-1.5"></span>
          <span class="block w-6 h-0.5 bg-stone-700"></span>
        </button>
        <ul id="nav-links" class="hidden lg:flex items-center gap-8 text-sm font-medium tracking-wide uppercase">
          <li><a href="/" class="hover:text-[#4a7c59] transition-colors">Accueil</a></li>
          <li><a href="/benjamin" class="hover:text-[#4a7c59] transition-colors">Benjamin</a></li>
          <li><a href="/chambre" class="hover:text-[#4a7c59] transition-colors">Chambre</a></li>
          <li><a href="/traiteur" class="hover:text-[#4a7c59] transition-colors">Traiteur</a></li>
          <li><a href="/menu-truffe" class="hover:text-[#4a7c59] transition-colors">Menu Truffe</a></li>
          <li>
            <a href="/contact" class="bg-[#4a7c59] text-white px-4 py-2 rounded-sm hover:bg-[#3d6b4c] transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </nav>
      <!-- Menu mobile -->
      <div id="mobile-menu" class="hidden lg:hidden bg-[#f8f4ee] border-t border-stone-200">
        <ul class="flex flex-col px-4 py-4 gap-4 text-sm font-medium tracking-wide uppercase">
          <li><a href="/" class="block hover:text-[#4a7c59]">Accueil</a></li>
          <li><a href="/benjamin" class="block hover:text-[#4a7c59]">Benjamin</a></li>
          <li><a href="/chambre" class="block hover:text-[#4a7c59]">Chambre</a></li>
          <li><a href="/traiteur" class="block hover:text-[#4a7c59]">Traiteur</a></li>
          <li><a href="/menu-truffe" class="block hover:text-[#4a7c59]">Menu Truffe</a></li>
          <li><a href="/contact" class="block hover:text-[#4a7c59]">Contact</a></li>
        </ul>
      </div>
    </header>

    <main class="pt-[72px]">
      <slot />
    </main>

    <footer class="bg-[#1a1a1a] text-stone-300 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <img src="/images/logo-blanc.svg" alt="Une Escale Gourmande" class="h-16 w-auto mb-4" />
          <p class="text-sm text-stone-400">Chambre d'hôte, traiteur & chef à domicile<br />au cœur du Périgord Vert</p>
        </div>
        <div>
          <h3 class="font-serif text-white text-lg mb-4">Navigation</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/chambre" class="hover:text-white transition-colors">Chambre d'hôte</a></li>
            <li><a href="/traiteur" class="hover:text-white transition-colors">Traiteur & Chef à domicile</a></li>
            <li><a href="/menu-truffe" class="hover:text-white transition-colors">Menu Truffe</a></li>
            <li><a href="/benjamin" class="hover:text-white transition-colors">Benjamin Jardin</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-serif text-white text-lg mb-4">Contact</h3>
          <ul class="space-y-2 text-sm">
            <li>1144 route des calvaires</li>
            <li>24800 Eyzerac — Périgord Vert</li>
            <li>
              <a href="tel:+33625142608" class="hover:text-white transition-colors">06 25 14 26 08</a>
            </li>
            <li>
              <a href="mailto:jardinbenjamin@hotmail.fr" class="hover:text-white transition-colors">jardinbenjamin@hotmail.fr</a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-stone-800 py-4 text-center text-xs text-stone-500">
        © {new Date().getFullYear()} Une Escale Gourmande — Benjamin Jardin
      </div>
    </footer>

    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
