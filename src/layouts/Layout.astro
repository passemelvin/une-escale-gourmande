---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: object;
}

const { title, description, image = '/images/terrasse-dejeuner.jpg', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const mapsURL = "https://www.google.com/maps/search/?api=1&query=1144+route+des+calvaires+24800+Eyzerac";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>

  <body>
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#f5f0e6]/95 backdrop-blur-sm border-b border-stone-200">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img src="/images/logo.svg" alt="Une Escale Gourmande" class="h-12 w-auto" />
          <span class="font-serif text-lg text-[#1a1a1a] hidden sm:block">Une Escale Gourmande</span>
        </a>
        <button id="menu-btn" class="lg:hidden p-2" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-stone-700 mb-1.5"></span>
          <span class="block w-6 h-0.5 bg-stone-700 mb-1.5"></span>
          <span class="block w-6 h-0.5 bg-stone-700"></span>
        </button>
        <ul id="nav-links" class="hidden lg:flex items-center gap-8 text-sm font-medium tracking-wide uppercase">
          <li><a href="/" class="hover:text-[#2d6a4f] transition-colors">Accueil</a></li>
          <li><a href="/benjamin" class="hover:text-[#2d6a4f] transition-colors">Le Chef</a></li>
          <li><a href="/chambre" class="hover:text-[#2d6a4f] transition-colors">Chambre</a></li>
          <li><a href="/traiteur" class="hover:text-[#2d6a4f] transition-colors">Traiteur</a></li>
          <li><a href="/menu-truffe" class="hover:text-[#2d6a4f] transition-colors">Menu Truffe</a></li>
          <li>
            <a href="/contact" class="bg-[#2d6a4f] text-white px-4 py-2 rounded-sm hover:bg-[#1b4332] transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </nav>
      <!-- Menu mobile -->
      <div id="mobile-menu" class="hidden lg:hidden bg-[#f5f0e6] border-t border-stone-200">
        <ul class="flex flex-col px-4 py-4 gap-4 text-sm font-medium tracking-wide uppercase">
          <li><a href="/" class="block hover:text-[#2d6a4f]">Accueil</a></li>
          <li><a href="/benjamin" class="block hover:text-[#2d6a4f]">Le Chef</a></li>
          <li><a href="/chambre" class="block hover:text-[#2d6a4f]">Chambre</a></li>
          <li><a href="/traiteur" class="block hover:text-[#2d6a4f]">Traiteur</a></li>
          <li><a href="/menu-truffe" class="block hover:text-[#2d6a4f]">Menu Truffe</a></li>
          <li><a href="/contact" class="block hover:text-[#2d6a4f]">Contact</a></li>
        </ul>
      </div>
    </header>

    <main class="pt-[72px]">
      <slot />
    </main>

    <footer class="bg-[#1a1a1a] text-stone-300 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-center md:text-left">
        <div class="flex flex-col items-center md:items-start">
          <img src="/images/logo-blanc.svg" alt="Une Escale Gourmande" class="h-16 w-auto mb-4" />
          <p class="text-sm text-stone-400">Chambre d'hôte, traiteur & chef à domicile<br />au cœur du Périgord Vert</p>
        </div>
        <div class="flex flex-col items-center md:items-start">
          <h3 class="font-serif text-white text-lg mb-4">Navigation</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/chambre" class="hover:text-white transition-colors">Chambre d'hôte</a></li>
            <li><a href="/traiteur" class="hover:text-white transition-colors">Traiteur & Chef à domicile</a></li>
            <li><a href="/menu-truffe" class="hover:text-white transition-colors">Menu Truffe</a></li>
            <li><a href="/benjamin" class="hover:text-white transition-colors">Le Chef</a></li>
          </ul>
        </div>
        <div class="flex flex-col items-center md:items-start">
          <h3 class="font-serif text-white text-lg mb-4">Contact</h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href={mapsURL} target="_blank" rel="noopener" class="hover:text-white transition-colors flex items-center gap-2 justify-center md:justify-start">
                <span>📍</span>
                <span>1144 route des calvaires<br />24800 Eyzerac — Périgord Vert</span>
              </a>
            </li>
            <li>
              <a href="tel:+33625142608" class="hover:text-white transition-colors">06 25 14 26 08</a>
            </li>
            <li>
              <a href="mailto:jardinbenjamin@hotmail.fr" class="hover:text-white transition-colors">jardinbenjamin@hotmail.fr</a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-stone-800 py-4 text-center text-xs text-stone-500">
        © {new Date().getFullYear()} Une Escale Gourmande — Benjamin Jardin
      </div>
    </footer>

    <!-- Lightbox -->
    <div id="lightbox" class="hidden fixed inset-0 z-[200] bg-black/92 flex items-center justify-center" role="dialog" aria-modal="true">
      <button id="lb-close" class="absolute top-5 right-6 text-white text-5xl font-thin leading-none hover:text-stone-300 transition-colors z-10" aria-label="Fermer">✕</button>
      <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-5xl font-thin leading-none hover:text-stone-300 transition-colors z-10 px-3 py-2" aria-label="Précédent">‹</button>
      <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-5xl font-thin leading-none hover:text-stone-300 transition-colors z-10 px-3 py-2" aria-label="Suivant">›</button>
      <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[80vw] object-contain select-none" />
      <p id="lb-counter" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/50 text-sm"></p>
    </div>

    <script>
      // Mobile menu
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Scroll reveal
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('main section').forEach(el => {
        el.classList.add('reveal');
        revealObserver.observe(el);
      });

      // Lightbox avec navigation
      const lightbox = document.getElementById('lightbox') as HTMLElement | null;
      const lbImg = document.getElementById('lb-img') as HTMLImageElement | null;
      const lbCounter = document.getElementById('lb-counter') as HTMLElement | null;

      const allImgs = Array.from(document.querySelectorAll<HTMLImageElement>('main img'));
      let currentIdx = 0;

      function showImg(idx: number) {
        if (!lbImg || !lbCounter) return;
        currentIdx = (idx + allImgs.length) % allImgs.length;
        lbImg.src = allImgs[currentIdx].src;
        lbImg.alt = allImgs[currentIdx].alt;
        lbCounter.textContent = `${currentIdx + 1} / ${allImgs.length}`;
      }

      function openLb(idx: number) {
        if (!lightbox) return;
        showImg(idx);
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function closeLb() {
        lightbox?.classList.add('hidden');
        document.body.style.overflow = '';
      }

      allImgs.forEach((img, idx) => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => openLb(idx));
      });

      document.getElementById('lb-close')?.addEventListener('click', closeLb);
      document.getElementById('lb-prev')?.addEventListener('click', (e) => { e.stopPropagation(); showImg(currentIdx - 1); });
      document.getElementById('lb-next')?.addEventListener('click', (e) => { e.stopPropagation(); showImg(currentIdx + 1); });

      lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLb(); });

      document.addEventListener('keydown', e => {
        if (!lightbox?.classList.contains('hidden')) {
          if (e.key === 'Escape') closeLb();
          if (e.key === 'ArrowLeft') showImg(currentIdx - 1);
          if (e.key === 'ArrowRight') showImg(currentIdx + 1);
        }
      });
    </script>
  </body>
</html>
