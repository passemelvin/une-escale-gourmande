---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "BedAndBreakfast",
  "name": "Une Escale Gourmande",
  "telephone": "+33625142608",
  "email": "jardinbenjamin@hotmail.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1144 route des calvaires",
    "addressLocality": "Eyzerac",
    "postalCode": "24800",
    "addressCountry": "FR",
    "addressRegion": "Dordogne"
  },
  "url": "https://uneescalegourmande.fr/contact"
};
---

<Layout
  title="Contact & Réservation — Une Escale Gourmande à Eyzerac"
  description="Contactez Benjamin Jardin pour réserver la chambre d'hôte, un repas, un service traiteur ou le menu truffe. Eyzerac, Périgord Vert — 06 25 14 26 08."
  schema={schema}
>
  <section class="max-w-5xl mx-auto px-4 py-20">
    <div class="text-center mb-16">
      <p class="text-sm uppercase tracking-widest text-[#2d6a4f] mb-3">Prenons contact</p>
      <h1 class="font-serif text-4xl md:text-5xl">Réserver ou renseigner</h1>
      <p class="text-stone-500 mt-4 max-w-xl mx-auto">Benjamin répond rapidement, de préférence par téléphone ou WhatsApp pour échanger sur votre projet.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- INFOS CONTACT -->
      <div class="space-y-8">
        <div>
          <h2 class="font-serif text-xl mb-5">Coordonnées</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <span class="text-2xl">📞</span>
              <div>
                <p class="font-medium">Téléphone & WhatsApp</p>
                <a href="tel:+33625142608" class="text-[#2d6a4f] text-lg hover:underline block mb-2">06 25 14 26 08</a>
                <a
                  href="https://wa.me/33625142608?text=Bonjour%20Benjamin%2C%20je%20vous%20contacte%20depuis%20votre%20site%20Une%20Escale%20Gourmande."
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 bg-[#25D366] text-white px-4 py-2 text-sm font-medium hover:bg-[#1fba59] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Contacter sur WhatsApp
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">✉️</span>
              <div>
                <p class="font-medium">Email</p>
                <a href="mailto:jardinbenjamin@hotmail.fr" class="text-[#2d6a4f] hover:underline">jardinbenjamin@hotmail.fr</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">📍</span>
              <div>
                <p class="font-medium">Adresse</p>
                <p class="text-stone-600">1144 route des calvaires<br />24800 Eyzerac<br />Périgord Vert, Dordogne</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-[#ede7d8] p-6">
          <h3 class="font-serif text-lg mb-4">Accès</h3>
          <ul class="space-y-2 text-sm text-stone-600">
            <li>🚗 À 8 km de Thiviers</li>
            <li>🚗 À 35 km de Périgueux</li>
            <li>🚗 À 45 km de Brive-la-Gaillarde</li>
          </ul>
        </div>

        <!-- Google Maps embed -->
        <div class="aspect-video w-full overflow-hidden">
          <iframe
            title="Localisation Une Escale Gourmande Eyzerac"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2758.5!2d0.9!3d45.4!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDXCsDI0JzAwLjAiTiAwwrA1NCcwMC4wIkU!5e0!3m2!1sfr!2sfr!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <!-- FORMULAIRE -->
      <div>
        <h2 class="font-serif text-xl mb-5">Formulaire de contact</h2>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-5"
          id="contact-form"
        >
          <input type="hidden" name="access_key" value="REMPLACER_PAR_CLE_WEB3FORMS" />
          <input type="hidden" name="subject" value="Nouveau message — Une Escale Gourmande" />
          <input type="hidden" name="from_name" value="Une Escale Gourmande" />
          <input type="hidden" name="redirect" value="https://une-escale-gourmande.passe-melvin.workers.dev/contact?merci=1" />
          <div>
            <label for="nom" class="block text-sm font-medium text-stone-700 mb-1">Nom *</label>
            <input type="text" id="nom" name="nom" required class="w-full border border-stone-300 px-4 py-2.5 focus:outline-none focus:border-[#2d6a4f] bg-white" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-stone-700 mb-1">Email *</label>
            <input type="email" id="email" name="email" required class="w-full border border-stone-300 px-4 py-2.5 focus:outline-none focus:border-[#2d6a4f] bg-white" />
          </div>
          <div>
            <label for="telephone" class="block text-sm font-medium text-stone-700 mb-1">Téléphone</label>
            <input type="tel" id="telephone" name="telephone" class="w-full border border-stone-300 px-4 py-2.5 focus:outline-none focus:border-[#2d6a4f] bg-white" />
          </div>
          <div>
            <label for="sujet" class="block text-sm font-medium text-stone-700 mb-1">Sujet *</label>
            <select id="sujet" name="sujet" required class="w-full border border-stone-300 px-4 py-2.5 focus:outline-none focus:border-[#2d6a4f] bg-white">
              <option value="">Choisir...</option>
              <option value="chambre">Chambre d'hôte</option>
              <option value="traiteur">Traiteur / Chef à domicile</option>
              <option value="menu-truffe">Menu Truffe</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-stone-700 mb-1">Message *</label>
            <textarea id="message" name="message" rows="5" required class="w-full border border-stone-300 px-4 py-2.5 focus:outline-none focus:border-[#2d6a4f] bg-white resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-[#2d6a4f] text-white py-3 font-medium hover:bg-[#1b4332] transition-colors">
            Envoyer le message
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
