---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FoodEstablishment",
  "name": "Traiteur & Chef à domicile — Une Escale Gourmande",
  "description": "Benjamin Jardin, chef traiteur et chef à domicile en Dordogne, Corrèze et Haute-Vienne. Mariages, baptêmes, repas d'entreprise, chef privé. Jusqu'à 120 personnes.",
  "url": "https://uneescalegourmande.fr/traiteur",
  "telephone": "+33625142608",
  "email": "jardinbenjamin@hotmail.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1144 route des calvaires",
    "addressLocality": "Eyzerac",
    "postalCode": "24800",
    "addressCountry": "FR"
  },
  "areaServed": ["Dordogne", "Corrèze", "Haute-Vienne"],
  "servesCuisine": ["Française", "Gastronomique", "Bistronomie"]
};
---

<Layout
  title="Traiteur & Chef à domicile Dordogne — Périgord | Une Escale Gourmande"
  description="Benjamin Jardin, chef traiteur et chef à domicile. Mariages, baptêmes, repas d'entreprise en Dordogne, Corrèze et Haute-Vienne. Cuisine gourmande et locale jusqu'à 120 personnes."
  image="/images/traiteur-assiettes.jpg"
  schema={schema}
>
  <!-- HERO -->
  <section class="relative h-[65vh] min-h-[450px] flex items-end overflow-hidden">
    <img src="/images/traiteur-assiettes.jpg" alt="Service traiteur gastronomique" class="absolute inset-0 w-full h-full object-cover object-top" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/65 to-transparent"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 pb-12 w-full">
      <p class="text-white/70 text-sm uppercase tracking-widest mb-2">Événements</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white">Traiteur & Chef à domicile</h1>
      <p class="text-white/80 mt-2 text-lg font-light">Dordogne · Corrèze · Haute-Vienne</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <h2 class="font-serif text-3xl mb-6">Une cuisine sur-mesure pour vos événements</h2>
    <p class="text-lg text-stone-600 leading-relaxed">
      Chef cuisinier de métier depuis 20 ans, Benjamin Jardin met son savoir-faire à votre service pour tous types d'événements. Une cuisine gourmande et inventive autour de produits locaux, en laissant une belle place au végétal et aux associations de saveurs originales.
    </p>
  </section>

  <!-- DEUX FORMULES -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Traiteur -->
        <div class="border border-stone-200 p-8">
          <h3 class="font-serif text-2xl mb-4 text-[#2d6a4f]">Traiteur</h3>
          <p class="text-stone-600 leading-relaxed mb-6">
            Benjamin prépare et livre vos repas, entièrement cuisinés avec des produits frais et locaux. Une solution clé en main pour vos événements, quel que soit le nombre de convives.
          </p>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex items-start gap-2"><span class="text-[#2d6a4f] mt-1">✓</span> Buffets & cocktails dînatoires</li>
            <li class="flex items-start gap-2"><span class="text-[#2d6a4f] mt-1">✓</span> Repas assis servis</li>
            <li class="flex items-start gap-2"><span class="text-[#2d6a4f] mt-1">✓</span> Brunch & déjeuners</li>
            <li class="flex items-start gap-2"><span class="text-[#2d6a4f] mt-1">✓</span> Livraison et mise en place</li>
          </ul>
        </div>

        <!-- Chef à domicile -->
        <div class="border border-stone-200 p-8">
          <h3 class="font-serif text-2xl mb-4 text-[#3b6b8a]">Chef à domicile</h3>
          <p class="text-stone-600 leading-relaxed mb-6">
            Benjamin se déplace directement chez vous ou dans votre lieu de réception pour cuisiner en live. Une expérience immersive qui fait de votre cuisine le cœur de l'événement.
          </p>
          <ul class="space-y-2 text-stone-600 text-sm">
            <li class="flex items-start gap-2"><span class="text-[#3b6b8a] mt-1">✓</span> Repas en domaines & châteaux</li>
            <li class="flex items-start gap-2"><span class="text-[#3b6b8a] mt-1">✓</span> Dîners privés à domicile</li>
            <li class="flex items-start gap-2"><span class="text-[#3b6b8a] mt-1">✓</span> Menu truffe en saison</li>
            <li class="flex items-start gap-2"><span class="text-[#3b6b8a] mt-1">✓</span> Menu sur-mesure selon vos souhaits</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- OCCASIONS -->
  <section class="py-16 max-w-5xl mx-auto px-4">
    <h2 class="font-serif text-2xl text-center mb-10">Pour toutes les occasions</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {[
        { icon: "💍", label: "Mariages" },
        { icon: "👶", label: "Baptêmes" },
        { icon: "🏢", label: "Repas d'entreprise" },
        { icon: "👨‍👩‍👧‍👦", label: "Repas de famille" },
        { icon: "🏰", label: "Domaines & châteaux" },
        { icon: "☀️", label: "Brunchs" },
        { icon: "🎉", label: "Anniversaires" },
        { icon: "🍂", label: "Menu truffe" },
      ].map(item => (
        <div class="p-4 bg-[#f5f0e6] hover:bg-[#ede7d8] transition-colors">
          <div class="text-3xl mb-2">{item.icon}</div>
          <p class="text-sm font-medium text-stone-700">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ZONE + CAPACITÉ -->
  <section class="bg-[#ede7d8] py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 text-center">
        <div>
          <div class="text-5xl font-serif text-[#2d6a4f] mb-3">120</div>
          <p class="font-medium text-stone-700 mb-2">personnes maximum</p>
          <p class="text-stone-500 text-sm">Benjamin s'adapte aussi bien aux petits dîners intimes qu'aux grandes réceptions.</p>
        </div>
        <div>
          <div class="text-3xl mb-3">📍</div>
          <p class="font-medium text-stone-700 mb-2">Zone d'intervention</p>
          <p class="text-stone-600 text-sm">Dans un rayon de <strong>40 km autour de Thiviers</strong></p>
          <p class="text-stone-500 text-sm mt-1">Dordogne · Corrèze · Haute-Vienne</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERIE -->
  <section class="py-16 max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <img src="/images/entree-oeuf-jambon.jpg" alt="Entrée gastronomique" class="w-full aspect-square object-cover" />
      <img src="/images/amuse-bouches.jpg" alt="Amuse-bouches traiteur" class="w-full aspect-square object-cover" />
      <img src="/images/risotto-champignons.webp" alt="Plat principal" class="w-full aspect-square object-cover" />
      <img src="/images/dessert-tarte-fruits.jpg" alt="Dessert de saison" class="w-full aspect-square object-cover" />
      <img src="/images/verrine-chocolat.webp" alt="Verrine au chocolat" class="w-full aspect-square object-cover" />
      <img src="/images/dessert-fraise.jpg" alt="Dessert aux fraises" class="w-full aspect-square object-cover" />
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-[#1b4332] py-24 text-center px-4">
    <div class="absolute inset-0 bg-[url('/images/traiteur-assiettes.jpg')] bg-cover bg-center opacity-10"></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <p class="text-[#52b788] text-sm uppercase tracking-widest mb-4">Devis gratuit</p>
      <h2 class="font-serif text-3xl md:text-4xl text-white mb-5">Un projet ? Parlons-en.</h2>
      <p class="text-white/70 mb-10 text-lg">Chaque événement est unique. Benjamin établit un devis personnalisé selon vos besoins, votre lieu et votre budget.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+33625142608" class="inline-block bg-white text-[#1b4332] px-8 py-3 font-semibold hover:bg-[#f5f0e6] transition-colors">
          📞 06 25 14 26 08
        </a>
        <a href="https://wa.me/33625142608?text=Bonjour%20Benjamin%2C%20je%20vous%20contacte%20pour%20un%20projet%20traiteur." target="_blank" rel="noopener"
          class="inline-block bg-[#25D366] text-white px-8 py-3 font-semibold hover:bg-[#1fba59] transition-colors">
          WhatsApp
        </a>
        <a href="/contact" class="inline-block border border-white/50 text-white px-8 py-3 hover:bg-white/10 transition-colors">
          Formulaire de contact
        </a>
      </div>
    </div>
  </section>
</Layout>
